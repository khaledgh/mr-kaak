# ─────────────────────────────────────────────────────────────
# Restaurant API — environment configuration
# Copy to .env and fill in. NEVER commit .env.
# ─────────────────────────────────────────────────────────────

# App
APP_ENV=development            # development | staging | production
APP_NAME=restaurant-api
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
SHUTDOWN_TIMEOUT=20s
# Comma-separated list of allowed CORS origins (use * only in dev)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Logging
LOG_LEVEL=debug                # debug | info | warn | error
LOG_FORMAT=console             # console | json  (use json in production)

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=restaurant
DB_PASSWORD=restaurant
DB_NAME=restaurant_canada
DB_PARAMS=charset=utf8mb4&parseTime=true&loc=UTC
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=25
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m

# Redis (cache + Asynq + pub/sub)
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1

# Meilisearch
MEILI_HOST=http://127.0.0.1:7700
MEILI_MASTER_KEY=change-me-in-prod-please-32chars-min

# Auth (JWT) — set strong random secrets in production
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Default locale / currency
DEFAULT_LOCALE=en
CURRENCY=CAD

# Media / file uploads
UPLOAD_DIR=./uploads
PUBLIC_BASE_URL=http://127.0.0.1:8080       # change to your domain in production
MEDIA_MAX_BYTES=2097152                      # 2 MB per file
MEDIA_ALLOWED_MIME=image/jpeg,image/png,image/webp

# Web Push (VAPID) — generate a key pair; leave empty to disable push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
