# ??????????????????????????????????????????????????????????????
# Frontend (Customer App) — environment configuration
# Copy to .env and fill in. NEVER commit .env.
# ??????????????????????????????????????????????????????????????

# Vite exposes only VITE_* variables to browser code.

# Backend API base URL (proxied in dev, direct in production builds)
VITE_API_BASE_URL=/api/v1

# Dev server port
VITE_PORT=5173

# Backend URL used by the Vite dev proxy (only needed in local dev)
VITE_BACKEND_URL=http://127.0.0.1:8080

# App metadata
VITE_APP_NAME=mrkaak
VITE_APP_TITLE=MR Kaak - Arabic Sweets & Kaak

# PWA theme color
VITE_THEME_COLOR=#b45309
